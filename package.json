{
  "name": "shopinista-canva",
  "version": "1.0.3",
  "description": "Integración oficial de Shopinista con Canva para sincronizar imágenes, recursos y productos.",
  "type": "module",
  "main": "src/main.tsx",
  "scripts": {
    "dev": "vite",
    "build": "vite build && terser public/main.js -o public/main.min.js --compress --mangle",
    "preview": "vite preview",
    "start": "node server.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "validate": "node validate.js",
    "package": "npm run build && vercel --prod"
  },
  "keywords": [
    "shopinista",
    "canva",
    "integration",
    "react",
    "vite",
    "tailwind",
    "ecommerce"
  ],
  "author": "Marco Flores",
  "license": "MIT",
  "dependencies": {
    "@canva/design": "^2.7.3",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.360.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "autoprefixer": "^10.4.21",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "terser": "^5.44.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^7.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.45.0"
  }
}
