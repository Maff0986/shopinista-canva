{
  "name": "Shopinista Canva Integration",
  "description": "Generador de contenido visual desde feeds y plantillas Canva.",
  "version": "1.0.3",
  "manifest_version": 1,
  "icon": {
    "dark": "https://shopinista-canva.vercel.app/icons/icon-dark.png",
    "light": "https://shopinista-canva.vercel.app/icons/icon-light.png"
  },
  "base_url": "https://shopinista-canva.vercel.app",
  "activities": [
    {
      "activity": "edit_design:render",
      "url": "/app.js"
    }
  ],
  "permissions": {
    "network": {
      "urls": [
        "*"
      ]
    },
    "intents": [
      "edit_design:render",
      "content_generation:generate_text",
      "assets:import",
      "data:read"
    ]
  },
  "entrypoint": {
    "bundle": "https://shopinista-canva.vercel.app/"
  },
  "developer": {
    "name": "Shopinista",
    "website": "https://shopinista.com",
    "email": "support@shopinista.com"
  }
}